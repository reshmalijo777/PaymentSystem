<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title></title>
</head>
<body>
  <div>
    <h2>Select Merchant</h2>

    <select (change)="onMerchantSelect($event)">
      <option value="">Choose a merchant...</option>
      <option value="merchant-a">Merchant A</option>
      <option value="merchant-b">Merchant B</option>
    </select>



    <div *ngIf="merchant()">
      <h3 [style.color]="merchant()?.primaryColor">{{ merchant()?.displayName }}</h3>
    </div>

    <form (ngSubmit)="submit()" [formGroup]="form">
      <input formControlName="amount" placeholder="Amount" type="number" />
      <input formControlName="cardNumber" placeholder="Card Number" />
      <input formControlName="expiryMonth" type="number" min="1" max="12" />
      <input formControlName="expiryYear" type="number" />
      <input formControlName="cvv" placeholder="CVV" />
      <input formControlName="customerEmail" type="email" placeholder="Email" />
      <button type="submit">Submit</button>
    </form>
  </div>

</body>
</html>
